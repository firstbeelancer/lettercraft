# --- PostgreSQL ---
POSTGRES_DB=lettercraft
POSTGRES_USER=lettercraft
POSTGRES_PASSWORD=lettercraft

# --- API ---
# Сгенерируйте: openssl rand -base64 48
JWT_SECRET=replace-me-with-random-secret-min-32-chars

# Внешний URL приложения, используется в magic link.
# В Coolify должен соответствовать домену, на котором работает фронт.
APP_URL=https://lettercraft.tigerapps.pro

# CORS_ORIGINS — через запятую. Если пусто — разрешены все origin (для dev).
CORS_ORIGINS=https://lettercraft.tigerapps.pro

# --- SMTP (опционально) ---
# Если не заполнено — magic link пишется в логи api-контейнера (видно через
# `docker logs <api-container>` или в Coolify → приложение → Logs).
# SMTP_HOST=smtp.yandex.ru
# SMTP_PORT=587
# SMTP_USER=noreply@tehgid.com
# SMTP_PASS=secret
# SMTP_FROM=LetterCraft <noreply@tehgid.com>
