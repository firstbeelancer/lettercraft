{
  "name": "lettercraft",
  "version": "1.0.0",
  "private": true,
  "description": "LetterCraft — конструктор корпоративных писем (миграция с Lovable)",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:api": "npm --workspace apps/api run dev",
    "build:api": "npm --workspace apps/api run build",
    "migrate": "npm --workspace apps/api run migrate",
    "seed": "npm --workspace apps/api run seed"
  }
}
